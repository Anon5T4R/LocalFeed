{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalFeed",
  "version": "0.5.0",
  "identifier": "com.localfeed.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1466",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalFeed",
        "width": 1200,
        "height": 760,
        "minWidth": 800,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "fileAssociations": [
      {
        "ext": ["opml"],
        "name": "Lista de feeds OPML",
        "description": "Assinaturas de feeds (OPML)",
        "role": "Viewer"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
